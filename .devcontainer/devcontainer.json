{
  "name": "drink-counter",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bookworm",

  // Linux ホストで host.docker.internal を解決できるようにする
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      }
    }
  },

  // アプリ + Supabase Studio のポートをフォワード
  "forwardPorts": [5173, 54321, 54323],

  // Supabase の Docker ネットワークに自動接続
  "postStartCommand": "docker network connect supabase_network_drink-counter $(hostname) 2>/dev/null || true"
}
